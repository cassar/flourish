<div class="card bg-base-200 border border-base-300 shadow-sm hover:border-primary/40 transition-colors">
  <div class="card-body">
    <div class="flex items-start justify-between gap-4">
      <div>
        <div class="text-xs font-semibold text-primary/70 uppercase tracking-widest">Dividend</div>
        <div class="text-3xl font-bold text-primary mt-1"><%= distribution.default_amount.amount_formatted %></div>
      </div>
      <span class="badge badge-outline badge-sm mt-1"><%= distribution_status dividend_statuses: distribution.dividends.pluck(:status) %></span>
    </div>
    <ul class="mt-3 space-y-1 text-sm text-base-content/70">
      <li><span class="font-semibold text-base-content/90">Date:</span> <%= created_at_formatted distribution %></li>
      <li><span class="font-semibold text-base-content/90">Distribution:</span> <%= distribution.name %></li>
      <li><span class="font-semibold text-base-content/90">Dividends:</span> <%= distribution.dividends.length %></li>
      <%= render 'aggregate_status_counts', disaggregate_status_counts: distribution.dividends.group(:status).count %>
    </ul>
    <div class="card-actions mt-3">
      <%= link_to "View Distribution", distribution_path(distribution), class: 'btn btn-primary btn-sm' %>
    </div>
  </div>
</div>
