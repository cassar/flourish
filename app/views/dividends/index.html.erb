<% content_for :title, 'Dividends' %>
<div class="space-y-6">
  <h1 class="text-3xl font-bold text-primary">Dividends</h1>
  <%= render partial: 'details' %>
  <% if @dividends.any? %>
    <div class="space-y-4">
      <%= render @dividends %>
    </div>
  <% else %>
    <div class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <p class="text-base-content/60 italic">Your dividends will appear here.</p>
      </div>
    </div>
  <% end %>
</div>
