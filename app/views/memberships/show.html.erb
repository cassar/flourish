<% content_for :title, 'Membership' %>

<div class="space-y-6 max-w-2xl mx-auto">

  <%# Header %>
  <div>
    <p class="text-xs uppercase tracking-widest text-primary/50 font-medium mb-1">Your membership</p>
    <h1 class="text-4xl text-primary" style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 700;">
      <%= @member.name.presence || current_user.email.split('@').first %>
    </h1>
    <p class="text-sm text-base-content/40 mt-1"><%= current_user.email %> &middot; Member since <%= current_user.created_at.to_datetime.strftime('%b %Y') %></p>
  </div>

  <%# PayPal.Me missing notice %>
  <% if @member.pay_outs_disabled? %>
    <div class="bg-warning/10 border border-warning/30 rounded-2xl px-5 py-4 flex items-start gap-4">
      <svg class="w-5 h-5 text-warning shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
      </svg>
      <div>
        <p class="text-sm font-medium text-base-content">No PayPal.Me handle set</p>
        <p class="text-xs text-base-content/50 mt-0.5">Add your PayPal.Me handle to receive dividend payouts. Until then, dividends will be automatically recontributed.</p>
        <%= link_to 'Add in Account settings →', edit_user_registration_path, class: 'text-xs text-primary hover:underline mt-1 inline-block' %>
      </div>
    </div>
  <% end %>

  <%# Stats %>
  <div class="grid grid-cols-3 gap-3">
    <div class="bg-base-200 rounded-2xl p-4 text-center">
      <p class="text-2xl font-bold text-base-content"><%= @total_contributed %></p>
      <p class="mt-1 text-xs uppercase tracking-widest text-base-content/40 font-medium">Contributed</p>
    </div>
    <div class="bg-base-200 rounded-2xl p-4 text-center">
      <p class="text-2xl font-bold text-base-content"><%= @total_dividends %></p>
      <p class="mt-1 text-xs uppercase tracking-widest text-base-content/40 font-medium">Earned</p>
    </div>
    <div class="bg-base-200 rounded-2xl p-4 text-center">
      <p class="text-2xl font-bold text-base-content"><%= @pending_payout_count %></p>
      <p class="mt-1 text-xs uppercase tracking-widest text-base-content/40 font-medium">Pending</p>
    </div>
  </div>

  <%# Past activity %>
  <div class="space-y-3">
    <p class="text-xs uppercase tracking-widest text-base-content/40 font-medium mb-3">Past activity</p>

    <%= link_to dividends_membership_path, class: 'flex items-center gap-3 bg-base-200 hover:bg-base-300 transition-colors rounded-2xl px-5 py-4' do %>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-base-content">Dividends</p>
        <p class="text-xs text-base-content/40 mt-0.5">Dividends you've received</p>
      </div>
      <svg class="w-4 h-4 text-base-content/30 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    <% end %>

    <%= link_to contributions_membership_path, class: 'flex items-center gap-3 bg-base-200 hover:bg-base-300 transition-colors rounded-2xl px-5 py-4' do %>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-base-content">Contributions</p>
        <p class="text-xs text-base-content/40 mt-0.5">What you've put in</p>
      </div>
      <svg class="w-4 h-4 text-base-content/30 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    <% end %>

    <%= link_to notifications_membership_path, class: 'flex items-center gap-3 bg-base-200 hover:bg-base-300 transition-colors rounded-2xl px-5 py-4' do %>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-base-content">Notifications</p>
        <p class="text-xs text-base-content/40 mt-0.5">Your alert preferences</p>
      </div>
      <svg class="w-4 h-4 text-base-content/30 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    <% end %>
  </div>

  <%# Actions %>
  <div class="flex flex-wrap gap-3 pb-2">
    <%= link_to 'Edit account', edit_user_registration_path, class: 'btn btn-outline btn-primary btn-sm rounded-xl' %>
    <%= button_to 'Sign out', destroy_user_session_path, method: :delete, class: 'btn btn-ghost btn-sm rounded-xl' %>
  </div>

</div>
