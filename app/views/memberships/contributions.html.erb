<% content_for :title, 'Contributions' %>

<div class="space-y-6 max-w-2xl mx-auto">

  <%= link_to membership_path, class: 'inline-flex items-center gap-1.5 text-xs text-base-content/40 hover:text-base-content/70' do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
    </svg>
    Membership
  <% end %>

  <div>
    <h1 class="text-2xl font-bold text-base-content">Contributions</h1>
  </div>

  <div class="rounded-2xl overflow-hidden border border-base-300">
    <% if @contributions.any? %>
      <% @contributions.each_with_index do |contribution, index| %>
        <div class="flex items-center gap-3 bg-base-100 px-4 py-3 <%= index < @contributions.size - 1 ? 'border-b border-base-200' : '' %>">
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-base-content"><%= contribution.created_at_formatted %></p>
            <% if contribution.distribution %>
              <p class="text-xs text-base-content/35 mt-0.5">Distribution <%= contribution.distribution.name %></p>
            <% else %>
              <p class="text-xs text-base-content/35 mt-0.5">Pool contribution</p>
            <% end %>
          </div>
          <span class="text-sm font-semibold text-primary shrink-0"><%= contribution.amount_formatted %></span>
        </div>
      <% end %>
    <% else %>
      <div class="bg-base-100 px-4 py-8 text-center text-sm text-base-content/40">
        No contributions yet.
      </div>
    <% end %>
  </div>

</div>
