<% content_for :title, 'Members' %>

<div class="space-y-6 max-w-4xl mx-auto">

  <%# Header %>
  <div class="flex items-end justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-widest text-primary/50 font-medium mb-1">Admin</p>
      <h1 class="text-4xl text-primary" style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 700;">Members</h1>
    </div>
    <p class="text-sm text-base-content/40 pb-1"><%= @members.size %> <%= @members.size == 1 ? 'member' : 'members' %></p>
  </div>

  <%# Search %>
  <%= form_with url: admin_members_path, method: :get, data: { turbo_frame: '_top' } do |f| %>
    <div class="flex gap-2">
      <%= f.text_field :q, value: params[:q], placeholder: 'Search by name or email…',
            class: 'input input-bordered rounded-xl flex-1 text-sm',
            autofocus: params[:q].present? %>
      <% if params[:q].present? %>
        <%= link_to 'Clear', admin_members_path, class: 'btn btn-ghost btn-sm rounded-xl self-center' %>
      <% end %>
    </div>
  <% end %>

  <%# Member grid %>
  <% if @members.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <% @members.each do |member| %>
        <%= link_to admin_member_path(member), class: 'bg-base-200 hover:bg-base-300 rounded-2xl p-5 flex flex-col gap-3 transition-colors group' do %>
          <div class="flex items-start justify-between gap-2">
            <div class="min-w-0">
              <p class="font-semibold text-base-content truncate group-hover:text-primary transition-colors">
                <%= member.name.presence || member.user.email.split('@').first %>
              </p>
              <p class="text-xs text-base-content/40 truncate mt-0.5"><%= member.user.email %></p>
            </div>
            <span class="badge badge-sm shrink-0 <%= member.user.last_sign_in_at? ? 'badge-success' : 'badge-neutral' %>">
              <%= member.user.last_sign_in_at? ? 'Active' : 'Pending' %>
            </span>
          </div>

          <div class="grid grid-cols-2 gap-2">
            <div class="bg-base-100 rounded-xl px-3 py-2 text-center">
              <p class="text-sm font-bold text-base-content"><%= member.contributions.count %></p>
              <p class="text-xs text-base-content/40 uppercase tracking-widest">Contrib.</p>
            </div>
            <div class="bg-base-100 rounded-xl px-3 py-2 text-center">
              <p class="text-sm font-bold text-base-content"><%= member.dividends.count %></p>
              <p class="text-xs text-base-content/40 uppercase tracking-widest">Divid.</p>
            </div>
          </div>

          <% if member.pay_outs_disabled? %>
            <p class="text-xs text-warning/70">No PayPal.Me set</p>
          <% else %>
            <p class="text-xs text-base-content/30 truncate">paypal.me/<%= member.paypalme_handle %></p>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-base-200 rounded-2xl px-4 py-12 text-center text-sm text-base-content/40">
      No members found<%= params[:q].present? ? " matching &ldquo;#{params[:q]}&rdquo;" : '' %>.
    </div>
  <% end %>

</div>
