<!DOCTYPE html>
<html>
  <head>
    <title><%= title_text yield(:title) %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <% if yield(:page_reload) %>
      <meta name="turbo-visit-control" content="reload">
    <% end %>
    <%= render 'application/favicon' %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="me" href="https://mastodon.social/@flourish_buzz">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,400;1,700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <body>
    <%= render layout_path %>
    <%= render 'layouts/footer' %>
  </body>
</html>
