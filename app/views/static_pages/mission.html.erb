<% content_for :title, 'Mission' %>
<div class="space-y-6">
  <h1 class="text-3xl font-bold text-primary">Mission</h1>

  <div class="card bg-base-200 shadow-sm">
    <div class="card-body space-y-4">
      <div>
        <h2 class="text-lg font-bold text-secondary mb-1">Mission</h2>
        <ul class="list-disc list-inside text-base-content/80 space-y-1">
          <li>Lives built on trust and meaningful work.</li>
        </ul>
      </div>
      <div>
        <h2 class="text-lg font-bold text-secondary mb-1">Goal</h2>
        <ul class="list-disc list-inside text-base-content/80 space-y-1">
          <li>To make it easier for everyone to support each other.</li>
        </ul>
      </div>
      <div>
        <h2 class="text-lg font-bold text-secondary mb-1">Value</h2>
        <p class="text-base-content/80"><span class="font-semibold text-accent">Trust</span>: In every human's innate goodness.</p>
        <ul class="list-disc list-inside text-base-content/80 space-y-1 mt-1">
          <li>Flourish will not require users to provide additional personal details beyond what it needs to determine personhood, communicate, and pay out funds.</li>
          <li>Flourish will not ask members what they plan on using their dividend for.</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="flex flex-wrap gap-3">
    <%= link_to 'Distributions', distributions_path, class: 'btn btn-outline btn-secondary' %>
    <%= render partial: 'authentication' %>
  </div>
</div>
