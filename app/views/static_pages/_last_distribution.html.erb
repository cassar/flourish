<div class="card bg-base-200 border border-base-300 shadow-sm">
  <div class="card-body">
    <div class="text-xs font-semibold text-base-content/50 uppercase tracking-widest">Last Dividend</div>
    <div class="text-4xl font-bold text-base-content/70 mt-1">
      <%= last_amount.amount_formatted %>
    </div>
    <ul class="mt-4 space-y-1 text-sm text-base-content/70">
      <li><span class="font-semibold text-base-content/90">Date:</span> <%= created_at_formatted last_distribution %></li>
      <li><span class="font-semibold text-base-content/90">Distribution:</span> <%= last_distribution.name %></li>
      <li><span class="font-semibold text-base-content/90">Status:</span>
        <span class="badge badge-outline badge-sm ml-1"><%= distribution_status dividend_statuses: last_distribution_dividends.pluck(:status) %></span>
      </li>
      <li><span class="font-semibold text-base-content/90">Dividends:</span> <%= last_distribution_dividends.length %></li>
      <%= render 'distributions/aggregate_status_counts', disaggregate_status_counts: last_distribution_dividends.group(:status).count %>
    </ul>
    <div class="card-actions mt-4">
      <%= link_to "View Distribution", distribution_path(last_distribution), class: 'btn btn-outline btn-sm' %>
    </div>
  </div>
</div>
