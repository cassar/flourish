<div class="card bg-base-200 border border-base-300 shadow-sm hover:border-secondary/40 transition-colors">
  <div class="card-body">
    <div class="flex items-start justify-between gap-4">
      <div>
        <div class="text-xs font-semibold text-secondary/70 uppercase tracking-widest">Dividend</div>
        <div class="text-3xl font-bold text-secondary mt-1"><%= dividend.amount.amount_formatted %></div>
      </div>
      <%
        status_class = case dividend.status
        when 'issued'         then 'badge-warning'
        when 'pay_out_complete' then 'badge-success'
        when 'recontributed'  then 'badge-info'
        else 'badge-outline'
        end
      %>
      <span class="badge <%= status_class %> badge-sm mt-1"><%= dividend.status.titleize %></span>
    </div>
    <ul class="mt-3 space-y-1 text-sm text-base-content/70">
      <li><span class="font-semibold text-base-content/90">Date:</span> <%= created_at_formatted dividend %></li>
      <li><span class="font-semibold text-base-content/90">Distribution:</span> <%= dividend.distribution.name %></li>
      <% if dividend.pay_out_complete? %>
        <li><span class="font-semibold text-base-content/90">Transaction ID:</span> <span class="font-mono text-xs"><%= dividend.pay_out.transaction_identifier %></span></li>
      <% end %>
    </ul>
    <% if dividend.issued? %>
      <div class="card-actions mt-4 gap-2">
        <%= button_to "Pay Out", pay_out_membership_dividend_path(dividend), method: :patch,
            class: "btn btn-primary btn-sm #{'btn-disabled' if @member.pay_outs_disabled?}",
            disabled: @member.pay_outs_disabled? %>
        <%= button_to "Recontribute", recontribute_membership_dividend_path(dividend), method: :patch,
            class: 'btn btn-outline btn-secondary btn-sm' %>
      </div>
    <% end %>
  </div>
</div>
