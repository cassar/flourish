<% content_for :title, "Notification Preferences" %>
<div class="space-y-6">
  <h1 class="text-3xl font-bold text-primary">Notification Preferences</h1>

  <%= form_with model: @member, url: notification_preferences_path, method: :patch do |member_form| %>
    <div class="card bg-base-200 shadow-sm">
      <div class="card-body">
        <% @notification_preferences.each do |notification_preference| %>
          <%= member_form.fields_for :notification_preferences_attributes, notification_preference, index: notification_preference.id do |np_form| %>
            <div class="form-control">
              <label class="label cursor-pointer justify-start gap-4">
                <%= np_form.hidden_field :id %>
                <%= np_form.checkbox :enabled, class: 'checkbox checkbox-primary' %>
                <span class="label-text"><%= notification_preference.notification_name.titleize %></span>
              </label>
            </div>
          <% end %>
        <% end %>
        <div class="card-actions mt-4 gap-3">
          <%= member_form.submit "Update", class: 'btn btn-primary' %>
          <%= link_to 'Cancel', edit_user_registration_path, class: 'btn btn-ghost' %>
        </div>
      </div>
    </div>
  <% end %>
</div>
