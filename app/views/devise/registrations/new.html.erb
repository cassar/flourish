<% content_for :title, 'Sign up' %>
<% content_for :page_reload, true %>

<div class="grid lg:grid-cols-2 gap-0 rounded-3xl overflow-hidden border border-base-300 shadow-xl">

  <%# Left: Brand panel %>
  <div class="bg-base-200 relative flex flex-col justify-between p-10 lg:p-14 overflow-hidden min-h-64">
    <div class="absolute -top-24 -right-24 w-72 h-72 rounded-full bg-primary/5 blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-16 -left-16 w-56 h-56 rounded-full bg-primary/8 blur-2xl pointer-events-none"></div>

    <div class="relative">
      <p class="text-xs uppercase tracking-widest text-primary/50 font-medium mb-8">Flourish</p>
      <h1 class="text-5xl lg:text-6xl text-primary leading-snug" style="font-family: 'Playfair Display', serif; font-style: italic; font-weight: 700; text-shadow: 0 0 60px oklch(38% 0.14 145 / 0.2);">
        Put<br>something<br>in.
      </h1>
      <p class="mt-5 text-base-content/50 text-sm leading-relaxed max-w-xs">
        Join the shared pool. Contribute what you can, and every Friday, members share in the returns.
      </p>
    </div>

    <div class="relative mt-10 lg:mt-0">
      <details class="group">
        <summary class="cursor-pointer list-none flex items-center gap-2 text-xs uppercase tracking-widest text-primary/50 font-medium select-none">
          <span class="w-5 h-px bg-primary/30"></span>
          What's required to join?
          <svg class="ml-auto w-3 h-3 text-base-content/30 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="mt-4 text-xs text-base-content/40 space-y-2 leading-relaxed pl-7">
          <p>It doesn't cost anything to join, and no minimum contribution is required.</p>
          <p>After email confirmation, new members are included in the weekly distributions and receive dividends.</p>
          <p>A <%= link_to 'PayPal.Me', 'https://www.paypal.com/au/digital-wallet/send-receive-money/paypal-me', target: '_blank', class: 'text-primary hover:underline' %> handle is needed to receive dividends and make contributions.</p>
        </div>
      </details>
    </div>
  </div>

  <%# Right: Form panel %>
  <div class="bg-base-100 flex flex-col justify-center p-8 lg:p-12">
    <h2 class="text-xl font-semibold text-base-content mb-1">Create your account</h2>
    <p class="text-sm text-base-content/40 mb-8">Join the pool and start sharing.</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-5">
        <div class="form-control">
          <%= f.label :email, class: 'label pb-1.5' do %>
            <span class="label-text text-xs uppercase tracking-widest text-base-content/40 font-medium">Email</span>
          <% end %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: 'input input-bordered w-full bg-base-200 border-base-300 rounded-xl' %>
        </div>

        <div class="form-control">
          <%= f.label :password, class: 'label pb-1.5' do %>
            <span class="label-text text-xs uppercase tracking-widest text-base-content/40 font-medium">Password</span>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: 'input input-bordered w-full bg-base-200 border-base-300 rounded-xl' %>
        </div>

        <div class="form-control">
          <%= f.label :password_confirmation, class: 'label pb-1.5' do %>
            <span class="label-text text-xs uppercase tracking-widest text-base-content/40 font-medium">Confirm Password</span>
          <% end %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: 'input input-bordered w-full bg-base-200 border-base-300 rounded-xl' %>
        </div>

        <div>
          <%= hcaptcha_tags %>
        </div>

        <div class="pt-1">
          <%= f.submit "Sign up", class: 'btn btn-primary w-full rounded-xl' %>
        </div>
      </div>
    <% end %>

    <div class="mt-8 pt-6 border-t border-base-200 text-sm text-center space-y-1.5">
      <%= render "devise/shared/links" %>
    </div>
  </div>

</div>
