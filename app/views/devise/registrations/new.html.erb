<% content_for :title, 'Sign up' %>
<% content_for :page_reload, true %>
<div class="flex justify-center">
  <div class="card bg-base-200 shadow-md w-full max-w-md">
    <div class="card-body">
      <h1 class="card-title text-2xl text-primary mb-2">Sign up</h1>
      <%= render partial: 'details' %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="form-control w-full mb-3">
          <%= f.label :email, class: 'label pb-1' do %>
            <span class="label-text font-semibold">Email</span>
          <% end %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: 'input input-bordered w-full' %>
        </div>

        <div class="form-control w-full mb-3">
          <%= f.label :password, class: 'label pb-1' do %>
            <span class="label-text font-semibold">Password</span>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: 'input input-bordered w-full' %>
        </div>

        <div class="form-control w-full mb-3">
          <%= f.label :password_confirmation, class: 'label pb-1' do %>
            <span class="label-text font-semibold">Confirm Password</span>
          <% end %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: 'input input-bordered w-full' %>
        </div>

        <div class="my-3">
          <%= hcaptcha_tags %>
        </div>

        <div class="form-control mt-2">
          <%= f.submit "Sign up", class: 'btn btn-primary w-full' %>
        </div>
      <% end %>

      <div class="divider text-xs text-base-content/40">or</div>
      <div class="text-sm text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
