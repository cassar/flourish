<% content_for :title, 'Log in' %>
<div class="flex justify-center">
  <div class="card bg-base-200 shadow-md w-full max-w-md">
    <div class="card-body">
      <h1 class="card-title text-2xl text-primary mb-2">Log in</h1>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="form-control w-full mb-3">
          <%= f.label :email, class: 'label pb-1' do %>
            <span class="label-text font-semibold">Email</span>
          <% end %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: 'input input-bordered w-full' %>
        </div>

        <div class="form-control w-full mb-3">
          <%= f.label :password, class: 'label pb-1' do %>
            <span class="label-text font-semibold">Password</span>
          <% end %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: 'input input-bordered w-full' %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="form-control mb-4">
            <label class="label cursor-pointer justify-start gap-3">
              <%= f.check_box :remember_me, class: 'checkbox checkbox-primary checkbox-sm' %>
              <span class="label-text">Remember me</span>
            </label>
          </div>
        <% end %>

        <div class="form-control mt-2">
          <%= f.submit "Log in", class: 'btn btn-primary w-full' %>
        </div>
      <% end %>

      <div class="divider text-xs text-base-content/40">or</div>
      <div class="text-sm text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
