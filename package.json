{
  "name": "app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "./node_modules/.bin/esbuild app/javascript/*.* --bundle --sourcemap --outdir=app/assets/builds --public-path=/assets",
    "build:css": "if [ \"$NODE_ENV\" = \"production\" ]; then ./node_modules/.bin/tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --minify; else ./node_modules/.bin/tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css; fi",
    "build:css:dev": "./node_modules/.bin/tailwindcss -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css",
    "lint:js": "./node_modules/.bin/eslint app/javascript"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@rails/actioncable": "^8.0.0",
    "@tailwindcss/cli": "^4.2.2",
    "daisyui": "^5.5.19",
    "esbuild": "^0.28.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0"
  }
}
